@page
@model Api.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<h1>Sign in</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="error">@Model.ErrorMessage</div>
}

<form method="post">
    <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />

    <label for="Email">Email</label>
    <input type="email" id="Email" name="Email" autocomplete="username" required value="@Model.Email" />

    <label for="Password">Password</label>
    <input type="password" id="Password" name="Password" autocomplete="current-password" required />

    <button type="submit">Sign in</button>
</form>

<p class="note">Dev seed: <code>globaladmin@@mystack.test</code> / <code>admin@@mystack.test</code> / <code>user@@mystack.test</code></p>
